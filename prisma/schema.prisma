generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

enum ReasonType {
  PLUS
  MINUS
  ETC
}

enum CaseStatus {
  OPEN
  CLOSED
  DISCONNECTED
}

enum CaseAction {
  OPEN
  CLOSE
}

enum SongStatus {
  PENDING
  APPROVED
  REJECTED
}

enum DormName {
  송죽관
  동백관
}

enum DormReportStatus {
  PENDING
  PROCESSING
  COMPLETED
}

model Student {
  id        Int     @id @default(autoincrement())
  stuid     Int     @unique
  name      String
  grade     Int
  class     Int
  num       Int
  point     Int     @default(0)
  user      User?
  points    Point[]

  @@map("students")
}

model User {
  id          Int         @id @default(autoincrement())
  stuid       Int         @unique
  password    String
  name        String
  studentId   Int?        @unique
  phoneNumber String?
  student     Student?    @relation(fields: [studentId], references: [id], onDelete: SetNull)
  givenPoints Point[]     @relation("TeacherPoints")
  dormUsers   DormUser[]
  reports     DormReport[]

  @@map("users")
}

model Reason {
  id      Int        @id @default(autoincrement())
  type    ReasonType
  point   Int
  comment String
  points  Point[]

  @@map("reasons")
}

model Point {
  id          Int      @id @default(autoincrement())
  studentId   Int
  teacherId   Int
  reasonId    Int
  baseDate    DateTime @db.Date
  updatedDate DateTime @updatedAt
  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  teacher     User     @relation("TeacherPoints", fields: [teacherId], references: [id], onDelete: Restrict)
  reason      Reason   @relation(fields: [reasonId], references: [id], onDelete: Restrict)

  @@index([studentId])
  @@index([teacherId])
  @@index([reasonId])
  @@map("points")
}

model Case {
  id          Int        @id
  status      CaseStatus @default(CLOSED)
  updatedDate DateTime   @updatedAt

  @@map("cases")
}

model CaseSchedule {
  id     Int        @id @default(autoincrement())
  date   DateTime
  action CaseAction

  @@map("case_schedules")
}

model Song {
  id       Int        @id @default(autoincrement())
  title    String
  url      String
  duration Int
  status   SongStatus @default(PENDING)

  @@map("songs")
}

model DormRoom {
  id         Int          @id @default(autoincrement())
  name       String       @unique
  capacity   Int
  grade      Int
  dormName   DormName
  dormUsers  DormUser[]
  dormReport DormReport[]

  @@map("dorm_rooms")
}

model DormUser {
  id          Int      @id @default(autoincrement())
  roomId      Int
  userId      Int
  year        Int
  semester    Int
  bedPosition Int
  room        DormRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([roomId])
  @@index([userId])
  @@unique([userId, year, semester])
  @@map("dorm_users")
}

model DormReport {
  id          Int              @id @default(autoincrement())
  userId      Int
  roomId      Int
  description String
  imageUrl    String?
  imageKey    String?
  status      DormReportStatus @default(PENDING)
  comment     String?
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  room        DormRoom         @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([roomId])
  @@map("dorm_reports")
}
